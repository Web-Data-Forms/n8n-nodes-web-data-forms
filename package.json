{
	"name": "@webdataforms/n8n-nodes-web-data-forms",
	"version": "1.0.1",
	"description": "The deepest n8n integration for any forms platform. Go beyond simple webhooks with full-lifecycle triggers, submission management, and deep submission/form workflow CRUD operations.",
	"license": "MIT",
	"homepage": "https://webdataforms.com",
	"keywords": [
		"n8n-community-node-package",
		"web-data-forms",
		"forms",
		"no code form builder",
		"form workflow",
		"automation",
		"brandable forms",
		"multi user",
		"smart forms",
		"data collection",
		"workflow automation"
	],
	"author": {
		"name": "Web Data Forms"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Web-Data-Forms/n8n-nodes-web-data-forms.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/WebDataFormsApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/WebDataForms/WebDataForms.node.js",
			"dist/nodes/WebDataForms/WebDataFormsTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
